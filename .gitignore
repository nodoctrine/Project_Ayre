# .gitignore for the PUBLIC repo (nodoctrine/Project_Ayre).
# This is the shippable app's own repo; all rules are relative to its root.

# --- Machine-local / personal (never commit) ---
.claude/
config/user_settings.json
ayre_workspace/

# --- Large binaries: come from the GitHub Releases page, not git (see USB_PREP.md) ---
# Keep the folders (and their README placeholders); ignore the actual binaries.
bin/*
!bin/README.md
python/*
!python/README.md

# --- Model weights: user-supplied, never in git ---
*.gguf
*.bin
*.safetensors

# --- RAG index: large generated artifact, lives in Ayre_Corpus/ (outside the app
#     tree) but blanket-ignore *.db anywhere so it can never be committed by accident.
#     The corpus dump + index db are user-built/consume-only (Distribution_Contents
#     'never-in-repo'); Ayre never fetches or ships them. See RAG_v0_Build_Plan.md.
*.db
*.db-wal
*.db-shm

# --- Python build artifacts ---
__pycache__/
*.py[cod]
